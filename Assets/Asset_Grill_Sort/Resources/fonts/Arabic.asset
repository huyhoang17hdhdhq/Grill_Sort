    characterSetSelectionMode: 7
    characterSequence: "لعب\r\nصعب\r\nصعب جدًا\r\nالصفحة الرئيسية\r\nالمتجر\r\nلوحة المتصدرين\r\nالفريق\r\nحقيبة الطيران\r\nالعرض\r\nالمهمة\r\nبدون إعلانات\r\nالمكافآت اليومية\r\nالمستوى\r\nعرض خاص\r\nحزمة المبتدئين\r\nحزمة محدودة\r\nحزمة كبيرة\r\nحزمة رائعة\r\nحزمة فائقة\r\nحزمة ممتازة\r\nحزمة أسطورية\r\nالإعدادات\r\nالموسيقى\r\nالصوت\r\nالاهتزاز\r\nاستعادة الشراء\r\nاملأ قلبك\r\nالقلب التالي بعد:\r\nمشاهدة\r\nممتلئ\r\nإزالة الإعلانات\r\nإزالة الإعلانات المقاطعة\r\nإزالة البانر السفلي\r\nالمكافأة\r\nتم الشراء\r\nالفوز\r\nضعف العملات\r\nنهاية اللعبة\r\nلا يوجد وقت كافي. إضافة المزيد؟\r\nإحياء\r\nفوري\r\nطلب فائت\r\nلا يوجد وقت كافي. تخطي؟\r\nتخطي\r\nمغادرة اللعبة\r\nستفقد حياة واحدة\r\nمغادرة\r\nخسارة\r\nالحصول على معزز\r\nمجاني\r\nالمطالبة\r\nالتخزين\r\nتركيبة أسياخ في التخزين\r\nتحديث\r\nإعادة ضبط جميع مواقع الأسياخ\r\nمكعب ثلج\r\nتجميد الوقت لمدة {0} ثانية\r\nشعلة الطهي\r\nإذابة الأسياخ بالحرارة\r\nشواية مخفية\r\nأكمل الطلب المطابق لفتح شواية جديدة\r\nرجل التوصيل\r\nأكمل طلب التوصيل قبل انتهاء الوقت\r\nسيخ مخفي\r\nالسيخ مخفي حتى وضعه على الشواية\r\nسيخ مجمد\r\nأكمل 3 طلبات لإذابة السيخ المجمد\r\nشواية حارة\r\nشواية مخصصة للطعام الحار\r\nالمهمة اليومية\r\nأكمل {0} مستويات\r\nتمت إحياء {0} مرات\r\nشوهد {0} إعلان\r\nشوي {0} مجموعة أسياخ\r\nاستخدم {0} حزمة\r\nاستخدم {0} شعلة\r\nاستخدم {0} ثلج\r\nاستخدم {0} تحديث\r\nتخطي {0} توصيلات\r\nالمستوى\r\nتم إحياؤه\r\nالإعلانات\r\nالأسياخ\r\nالحزمة\r\nالشعلة\r\nالثلج\r\nالتحديث\r\nالتوصيل\r\nالهدايا اليومية\r\nاليوم\r\nالمطالبة\r\nقريبًا\r\nتهانينا\r\nاضغط للمطالبة\r\nاللغة\r\nالمستوى الصعب\r\nالمستوى فائق الصعوبة\r\nحزمة الإحياء\r\nتصريح المعركة\r\nاختر سيخًا مجمدًا لتذويبه\r\nذهب\r\n<color=#FFE036>إزالة الإعلانات</color><br><color=#6BDEFF>الحزمة</color>\r\nقفل\r\nالوصول إلى المستوى {0} لفتح الترتيب!\r\nانضم إلى بطولة الترتيب واربح مكافآت مثيرة!\r\nالأسبوع\r\nالترتيب\r\nمسابقة أسبوعية\r\nانضم إلى الحدث\r\nانضم\r\nجارٍ التحميل\r\nالنتيجة\r\nتجاوز المستويات!\r\nكن في الصدارة!\r\nاربح المكافآت!\r\nاضغط للمتابعة\r\nتعديل الملف الشخصي\r\nمعرّف اللاعب\r\nالصورة الرمزية\r\nالإطار\r\nحفظ\r\nالملف الشخصي\r\nالإحصائيات العامة\r\nالمساعدة المقدمة\r\nالمساعدة المستلمة\r\nالفريق\r\nالوصول إلى المستوى {0} لفتح الفريق!\r\nعند الانضمام إلى فريق، ستحصل على:\r\n\\<color=#7CF73F>قلب</color> مجاني\r\n\\<color=#7CF73F>مكافآت</color> مجانية\r\nالفرق\r\nبحث\r\nإنشاء\r\nالسعة\r\nعرض\r\nمعلومات الفريق\r\nنقاط الفريق\r\nالمستوى المطلوب\r\nالنشاط\r\nترتيب الفريق\r\nمنذ\r\nالقائد\r\nمرتفع\r\nمتوسط\r\nمنخفض\r\nاسم الفريق\r\nشعار الفريق\r\nأدخل اسم الفريق...\r\nوصف الفريق\r\nأدخل وصف الفريق...\r\nالمستوى المطلوب\r\nتعديل الفريق\r\nسيحصل المركز الأول على مكافآته!\r\nالعالم\r\nالدولة\r\nالماستر\r\nفريقي\r\nرسالة\r\nطلب\r\nإرسال\r\nمساعدة\r\nيطلبون أرواحًا!\r\nتعديل\r\nمغادرة\r\nنقل القائد\r\nعرض الملف الشخصي\r\nإزالة عضو\r\nمغادرة الفريق؟\r\nنعم\r\nلا\r\nهل أنت متأكد أنك تريد مغادرة فريقك؟\r\nتنبيه\r\nتم حذف الفريق بنجاح!\r\nإغلاق\r\nأبدًا\r\nالآن فقط\r\nانضم للفريق\r\nلقد ترك الفريق\r\nلقد ركل الزعيم\r\nتم ترك الفريق بنجاح!\r\nانضمت للفريق بنجاح!\r\nتم إرسال طلب المساعدة بنجاح\r\nفشل تحميل قائمة مساعدة الفريق\r\nحياتكم مليئة بالفعل!\r\nتم تلقي المساعدة بنجاح!\r\nفشل في تلقي المساعدة\r\nفشل في إرسال المساعدة\r\nلا يمكن أن تكون الرسالة فارغة\r\nالرجاء تعيين اسم المستخدم الخاص بك أولاً\r\nتعذر إرسال الرسالة. يُرجى المحاولة مرة أخرى.\r\nفشل في إرسال طلب المساعدة\r\nيجب أن يتكون اسم الفريق من 3 أحرف على الأقل!\r\nلا يمكن أن يتجاوز اسم الفريق 15 حرفًا!\r\nالوصف لا يمكن أن يكون فارغا!\r\nالوصف لا يمكن أن يتجاوز 40 حرفًا!\r\nتم إنشاء الفريق بنجاح!\r\nالوصف لا يمكن أن يكون فارغا!\r\nتم تحديث معلومات الفريق بنجاح!\r\nخطأ في تحديث معلومات الفريق!\r\nخطأ في تحميل معلومات الفريق!\r\nتم حذف الفريق بنجاح!\r\nخطأ في حذف الفريق!\r\nتم ترك الفريق بنجاح!\r\nخطأ في مغادرة الفريق!\r\nيرجى تحديد اسم المستخدم الخاص بك قبل الانضمام إلى الفريق!\r\nانضمت للفريق بنجاح!\r\nفشل في الانضمام للفريق!\r\nلم يتم اختيار أي لاعب!\r\nفقط قائد الفريق هو من يستطيع ركل الأعضاء!\r\nتم ركل العضو بنجاح!\r\nفقط القائد هو الذي يستطيع الانتقال إلى عضو آخر!\r\nتم إنشاء الفريق بنجاح!\r\nفشل إنشاء الفريق. يُرجى المحاولة لاحقًا.\r\nالإصدار قديم. يُرجى التحديث إلى أحدث إصدار.\r\nتم توفير معلمات غير صالحة.\r\nتم رفض الإذن.\r\nتم الوصول إلى الحد الأقصى.\r\nحدث خطأ غير معروف.\r\nحدث خطأ أثناء معالجة الاستجابة.\r\nتم حذف الفريق بنجاح!\r\nخطأ في النظام\r\nتعذّر حذف الفريق. يُرجى المحاولة لاحقًا.\r\nلقد انضممت بالفعل إلى فريق آخر.\r\nأنت لست عضوًا في أي فريق.\r\nلقد غادرت فريقًا مؤخرًا. يُرجى الانتظار قبل الانضمام إلى فريق آخر.\r\nلا يُسمح لقائد الفريق بمغادرة الفريق. يُرجى نقل القيادة أولاً.\r\nليس لديك الإذن للقيام بهذا الإجراء.\r\nيوجد فريق بهذا الاسم بالفعل.\r\nالفريق غير موجود.\r\nالفريق ممتلئ.\r\nفشل\r\nانضمت للفريق بنجاح!\r\nتعذّر الحصول على تفاصيل الفريق. يُرجى المحاولة لاحقًا.\r\nتعذّر الانضمام للفريق. يُرجى المحاولة لاحقًا.\r\nقائد الفريق فقط هو من يستطيع نقل القيادة!\r\nلم يتم العثور على العضو المستهدف في الفريق!\r\nالعضو المستهدف هو القائد بالفعل!\r\nتم نقل القيادة بنجاح!\r\nفشل نقل القيادة!\r\n1234567890"
    referencedFontAssetGUID: ee481ceab510d4d41889d2f09ac0f35b
