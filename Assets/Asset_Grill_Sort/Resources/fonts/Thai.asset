  m_Material: {fileID: 2100000, guid: 0fffcae09aa343c48acbe01977273c2f, type: 2}
  m_SourceFontFileGUID: 1fd6517fd9f6d324d8010e0b3f86134e
  m_CreationSettings:
    sourceFontFileName:
    sourceFontFileGUID: 1fd6517fd9f6d324d8010e0b3f86134e
