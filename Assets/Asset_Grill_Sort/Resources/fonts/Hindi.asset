    characterSetSelectionMode: 7
    characterSequence: "खेलें\r\nकठिन\r\nअति कठिन\r\nहोम\r\nदुकान\r\nलीडरबोर्ड\r\nटीम\r\nजेटपैक\r\nऑफर\r\nक्वेस्ट\r\nविज्ञापन रहित\r\nदैनिक पुरस्कार\r\nस्तर\r\nविशेष ऑफर\r\nस्टार्टर पैक\r\nलिमिटेड पैक\r\nबड़ा बंडल\r\nशानदार बंडल\r\nअल्ट्रा बंडल\r\nसुपीरियर बंडल\r\nलिजेंडरी बंडल\r\nसेटिंग्स\r\nसंगीत\r\nध्वनि\r\nकंपन\r\nखरीदारी पुनर्स्थापित करें\r\nअपना दिल भरें\r\nअगला दिल समय:\r\nदेखें <sprite=10>\r\nपूर्ण <sprite=10>\r\nविज्ञापन हटाएं\r\nइंटरप्ट विज्ञापन हटाएं\r\nबॉटम बैनर हटाएं\r\nबोनस\r\nखरीदा गया\r\nजीत\r\nx2 सिक्के <sprite=10>\r\nगेम ओवर\r\nपर्याप्त समय नहीं। और जोड़ें?\r\nपुनर्जीवित <sprite=10>\r\nतुरंत\r\nछूटा हुआ ऑर्डर\r\nपर्याप्त समय नहीं। छोड़ें?\r\nछोड़ें <sprite=10>\r\nगेम छोड़ें\r\nआप 1 जीवन खो देंगे\r\nछोड़ें\r\nहार\r\nबूस्टर प्राप्त करें\r\nमुफ्त\r\nदावा करें\r\nभंडारण\r\nभंडारण स्केवर कॉम्बो\r\nताज़ा करें\r\nसभी स्केवर पोजीशन दोबारा सेट करें\r\nबर्फ का टुकड़ा\r\nसमय को {0} सेकंड के लिए फ्रीज करें\r\nकुकिंग टॉर्च\r\nगर्मी से स्केवर को डीफ्रॉस्ट करें\r\nछिपी हुई ग्रिल\r\nनई ग्रिल अनलॉक करने के लिए मिलान ऑर्डर पूरा करें\r\nडिलीवरीमैन\r\nसमय समाप्त होने से पहले डिलीवरी ऑर्डर पूरा करें\r\nछिपी हुई स्केवर\r\nस्केवर ग्रिल पर रखे जाने तक छिपी रहेगी\r\nजमी हुई स्केवर\r\nजमी स्केवर पिघलाने के लिए 3 ऑर्डर पूरे करें\r\nमसालेदार ग्रिल\r\nविशेष रूप से मसालेदार भोजन के लिए ग्रिल\r\nदैनिक क्वेस्ट\r\n{0} स्तर पूरे करें\r\n{0} बार पुनर्जीवित\r\n{0} विज्ञापन देखें\r\n{0} स्केवर सेट ग्रिल करें\r\n{0} पैक उपयोग करें\r\n{0} टॉर्च उपयोग करें\r\n{0} बर्फ उपयोग करें\r\n{0} ताज़ा करें उपयोग करें\r\n{0} डिलीवरी छोड़ें\r\nस्तर\r\nपुनर्जीवित\r\nविज्ञापन\r\nस्केवर\r\nपैक\r\nटॉर्च\r\nबर्फ\r\nताज़ा करें\r\nडिलीवरी\r\nदैनिक उपहार\r\nदिन\r\nदावा करें\r\nजल्दी आ रहा है\r\nबधाई हो\r\nप्राप्त करने के लिए टैप करें\r\nभाषा\r\nकठिन स्तर\r\nअति कठिन स्तर\r\nपुनर्जीवन पैक \r\nयुद्ध पास\r\nजमे हुए सीख को पिघलाने के लिए चुनें\r\nसोना\r\n<color=#FFE036>विज्ञापन हटाएँ</color><br><color=#6BDEFF>बंडल</color>\r\nलॉक\r\nरैंक अनलॉक करने के लिए स्तर {0} तक पहुँचें!\r\nरैंक टूर्नामेंट में शामिल हों और रोमांचक इनाम जीतें!\r\nसप्ताह\r\nरैंक\r\nसाप्ताहिक प्रतियोगिता\r\nइवेंट में शामिल हों\r\nशामिल हों\r\nलोड हो रहा है\r\nस्कोर\r\nस्तरों को पार करें!\r\nआगे बढ़ें!\r\nइनाम जीतें!\r\nजारी रखने के लिए टैप करें\r\nप्रोफ़ाइल संपादन\r\nप्लेयर आईडी\r\nअवतार\r\nफ़्रेम\r\nसहेजें\r\nप्रोफ़ाइल\r\nसामान्य आँकड़े\r\nदी गई सहायता\r\nप्राप्त सहायता\r\nटीम\r\nटीम अनलॉक करने के लिए स्तर {0} तक पहुँचें!\r\nजब आप किसी टीम में शामिल होते हैं、 आपको मिलेगा:\r\n<color=#7CF73F>मुफ़्त</color> दिल\r\n<color=#7CF73F>मुफ़्त</color> इनाम\r\nटीमें\r\nखोजें\r\nबनाएं\r\nक्षमता\r\nदेखें\r\nटीम जानकारी\r\nटीम स्कोर\r\nआवश्यक स्तर\r\nगतिविधि\r\nटीम रैंक\r\nपहले\r\nनेता\r\nउच्च\r\nमध्यम\r\nनिम्न\r\nटीम का नाम\r\nटीम लोगो\r\nटीम का नाम दर्ज करें...\r\nटीम विवरण\r\nटीम विवरण दर्ज करें...\r\nआवश्यक स्तर\r\nटीम संपादन\r\nपहले स्थान को उनके इनाम मिलेंगे!\r\nदुनिया\r\nदेश\r\nमास्टर\r\nमेरी टीम\r\nसंदेश\r\nअनुरोध\r\nभेजें\r\nमदद\r\nजिंदगी की मांग कर रहे हैं!\r\nसंपादित करें\r\nछोड़ें\r\nलीडर ट्रांसफर करें\r\nप्रोफ़ाइल देखें\r\nसदस्य को हटाएं\r\nटीम छोड़ें?\r\nहाँ\r\nनहीं\r\nक्या आप वाकई अपनी टीम छोड़ना चाहते हैं?\r\nचेतावनी\r\nटीम सफलतापूर्वक हटा दी गई!\r\nबंद करें\r\nकभी नहीं\r\nअभी अभी\r\nटीम में शामिल हो गया है\r\nटीम छोड़ दी है\r\nनेता ने लात मारी है\r\nटीम को सफलतापूर्वक छोड़ दिया!\r\nटीम में सफलतापूर्वक शामिल हो गए!\r\nसहायता अनुरोध सफलतापूर्वक भेजा गया\r\nटीम सहायता सूची लोड करने में विफल\r\nआपका जीवन पहले से ही पूर्ण है!\r\nसहायता सफलतापूर्वक प्राप्त हुई!\r\nसहायता प्राप्त करने में विफल\r\nसहायता भेजने में विफल\r\nसंदेश खाली नहीं रह सकता\r\nकृपया पहले अपना उपयोगकर्ता नाम सेट करें\r\nसंदेश नहीं भेजा जा सका। कृपया पुनः प्रयास करें\r\nसहायता अनुरोध भेजने में विफल\r\nटीम का नाम कम से कम 3 अक्षरों का होना चाहिए!\r\nटीम का नाम 15 अक्षरों से अधिक नहीं होना चाहिए!\r\nविवरण रिक्त नहीं हो सकता!\r\nविवरण 40 अक्षरों से अधिक नहीं हो सकता!\r\nटीम सफलतापूर्वक बनाई गई!\r\nविवरण रिक्त नहीं हो सकता!\r\nटीम की जानकारी सफलतापूर्वक अपडेट की गई!\r\nटीम जानकारी अद्यतन करने में त्रुटि!\r\nटीम जानकारी लोड करने में त्रुटि!\r\nटीम सफलतापूर्वक हटा दी गई!\r\nटीम हटाने में त्रुटि!\r\nटीम को सफलतापूर्वक छोड़ दिया!\r\nटीम छोड़ते समय त्रुटि हुई!\r\nकृपया किसी टीम में शामिल होने से पहले अपना उपयोगकर्ता नाम निर्धारित करें!\r\nटीम में सफलतापूर्वक शामिल हो गए!\r\nटीम में शामिल होने में असफल!\r\nकोई खिलाड़ी चयनित नहीं!\r\nकेवल टीम लीडर ही सदस्यों को लात मार सकता है!\r\nसदस्य सफलतापूर्वक लात मारी!\r\nकेवल नेता ही अन्य सदस्य को स्थानान्तरित कर सकता है!\r\nटीम सफलतापूर्वक बनाई गई!\r\nटीम बनाने में विफल। कृपया बाद में पुनः प्रयास करें।\r\nसंस्करण पुराना हो गया है। कृपया नवीनतम संस्करण में अपडेट करें।\r\nअमान्य पैरामीटर प्रदान किए गए.\r\nअनुमति नहीं मिली।\r\nहद हो गई।\r\nअज्ञात त्रुटि घटित हुई.\r\nप्रतिक्रिया संसाधित करते समय एक त्रुटि हुई.\r\nटीम सफलतापूर्वक हटा दी गई!\r\nसिस्टम त्रुटि\r\nटीम को हटाना विफल रहा। कृपया बाद में पुनः प्रयास करें।\r\nआप पहले ही किसी अन्य टीम में शामिल हो चुके हैं।\r\nआप किसी भी टीम के सदस्य नहीं हैं.\r\nआपने हाल ही में एक टीम छोड़ी है। कृपया किसी अन्य टीम में शामिल होने से पहले प्रतीक्षा करें।\r\nटीम लीडर टीम नहीं छोड़ सकता। कृपया पहले नेतृत्व हस्तांतरित करें।\r\nआपको यह कार्य करने की अनुमति नहीं है.\r\nइस नाम की एक टीम पहले से मौजूद है.\r\nटीम अस्तित्व में नहीं है.\r\nटीम पूरी है.\r\nअसफल\r\nटीम में सफलतापूर्वक शामिल हो गए!\r\nटीम विवरण प्राप्त करने में विफल। कृपया बाद में पुनः प्रयास करें।\r\nटीम में शामिल होने में विफल। कृपया बाद में पुनः प्रयास करें।\r\nकेवल टीम लीडर ही नेतृत्व हस्तांतरित कर सकता है!\r\nटीम में लक्ष्य सदस्य नहीं मिला!\r\nलक्ष्य सदस्य पहले से ही नेता है!\r\nनेतृत्व सफलतापूर्वक स्थानांतरित!\r\nनेतृत्व हस्तांतरण में असफल!\r\n1234567890"
