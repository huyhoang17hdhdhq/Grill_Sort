      textValue: Ngày {0}
    - textId: 413
      textValue: Đăng nhập 7 ngày để nhận phần thưởng giá trị
    - textId: 414
      textValue: Hoàn thành nhiệm vụ để thu thập vật phẩm đặc biệt!
    - textId: 415
      textValue: 'Sự kiện kết thúc sau: {0}'
    - textId: 416
      textValue: 'Giới hạn sự kiện:'
    - textId: 417
      textValue: 'Giới hạn hàng ngày:'
