    - textId: 423
      textValue: Bắt đầu với 100 người chơi
    - textId: 424
      textValue: Giành phần của bạn trong 10.000 vàng
    - textId: 425
      textValue: Bạn sẽ thất bại nếu thua 1 màn! Thắng 7 màn để hoàn thành thử thách!
    - textId: 426
      textValue: Gói
    - textId: 427
      textValue: Gói đặc biệt
    - textId: 428
      textValue: Bộ Bánh Trung Thu 1
    - textId: 429
      textValue: Bộ Bánh Trung Thu 2
    - textId: 430
      textValue: Bộ Bánh Trung Thu 3
    - textId: 431
      textValue: Ưu Đãi Hấp Dẫn
    - textId: 432
      textValue: Bán Chạy Nhất
    - textId: 433
      textValue: Mua tất cả <color=#FFE555>{0}% giảm giá
    - textId: 434
      textValue: ❤️ Tim đã hồi đầy!
    - textId: 435
      textValue: ❤️ Tim đã hồi đầy! Vào bếp ngay nào!
    - textId: 436
      textValue: 🍳 Trứng sắp cháy rồi kìa! Mau vào lật cho vàng giòn nào!
    - textId: 437
      textValue: 🥩 Vỉ nướng đang réo tên bạn – combo ngon đang đợi đó!
    - textId: 438
      textValue: 🌶️ Than đang đỏ lửa, vào nướng thêm vài xiên cho nóng tay đi!
    - textId: 439
      textValue: 🍢 Giờ cao điểm nướng xiên! Vào nhanh trước khi khói tan! 🔥
    - textId: 440
      textValue: 🧅 Rau củ sẵn sàng rồi! Chỉ chờ đôi tay phép thuật của bạn! ✨
    - textId: 441
      textValue: 🦐 Shrimp party chỉ còn 30 phút! 🦐🔥 vào chiến liền!
    - textId: 442
      textValue: 🌞 Giữa tuần rồi đó! Vào nướng vài xiên cho tỉnh người nào! 🍢🔥
    - textId: 443
      textValue: 🥗 Bụng kêu rồi đó! Salad tươi mát hay xiên nướng đậm vị đây? 🤔
    - textId: 444
      textValue: 🍫 Ngủ chưa? Vào nướng thêm một combo trước khi ngủ nhé! 🍢
    - textId: 445
      textValue: 🔥 Vỉ nướng nguội mất rồi, nhóm lửa lại thôi! 🔥
    - textId: 446
      textValue: 💰 Xu miễn phí đang đợi, vào nhận liền tay! 💰
    - textId: 447
      textValue: 🍔 Nhà bếp đang gọi bạn, đến nhận thưởng ngay thôi! 🍔
    - textId: 448
      textValue: 🍗Tiệc thứ sáu đến rồi, nhóm lửa lên thôi! 🔥
    - textId: 449
      textValue: 🎁 Thứ sáu có quà - vào nhận liền tay cho nóng! 🎁
    - textId: 450
      textValue: ⚡ Cả team đang trông chờ vào bạn—vào bếp chiến ngay! 🔥
    - textId: 451
      textValue: 👑 Thử thách cuối tuần đã mở—xem ai là bậc thầy nướng xiên nào! 👑
    - textId: 452
      textValue: 🔔 Vỉ nướng rực cháy, phần thưởng cháy hơn 🔔
    - textId: 453
      textValue: 💎 Cuối tuần tới rồi—xu nhân đôi, vui gấp bội! 💎
    - textId: 454
      textValue: 🔥 Ngày cuối tuần rồi—đừng để mất chuỗi, vào nướng ngay! 🔥
    - textId: 455
      textValue: 🎁 Cơ hội cuối nhận quà cuối tuần—vào ngay! 🎁
    - textId: 456
      textValue: 💪 Bếp Trưởng ơi, đối thủ của bạn vừa đạt 200 combo—vào phá kỷ lục ngay đi! 🔥
    - textId: 457
      textValue: 🔥 Nghỉ 7 ngày rồi! Quay lại nhận quà ngay! 🔥
    - textId: 458
      textValue: 🎁 Vắng 14 ngày! Trở lại liền để nhận quà đặc biệt! 🎁
    - textId: 459
      textValue: Tên
    - textId: 460
      textValue: Huy hiệu
    - textId: 461
      textValue: Vượt qua các màn chơi mà không thua
    - textId: 462
      textValue: Tăng hệ số điểm của bạn!
    - textId: 463
      textValue: Mỗi lần thất bại sẽ đặt lại hệ số nhân!
    - textId: 464
      textValue: THỬ ĐẦU TIÊN SẼ THẮNG
